PORT=4000
JWT_SECRET=replace_with_long_random_string_in_production
CORS_ORIGIN=http://localhost:3000

# Cloudflare R2 (S3-compatible) — image upload (/api/v1/upload/image)
# Use keys from: Dashboard → R2 → "Manage R2 API Tokens" → Create API token →
#   Permission: Object Read & Write → Buckets: your bucket (e.g. charkhub).
# (Account API tokens / cfat_... are for Cloudflare API, not the S3 PutObject keys here.)
# Endpoint: Dashboard → R2 → S3 API → copy "https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# Either pair works (S3 client keys from "Manage R2 API Tokens"):
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
R2_BUCKET=charkhub
# Bucket → Settings → Public access → allow r2.dev (or custom domain). Paste base URL, no trailing slash.
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
# Optional: set R2_FORCE_PATH_STYLE=1 if uploads fail with signature errors (default off in code).

# MongoDB (required). Example matches docker-compose.yml at repo root.
DATABASE_URL="mongodb://localhost:27017/chakrebd"

# Set to 1 behind nginx / load balancer so client IP and HTTPS are correct.
TRUST_PROXY=0

# Bootstrap: first start creates this user if missing (role super_admin). Change password in production.
SUPER_ADMIN_EMAIL=superadmin@yourdomain.com
SUPER_ADMIN_PASSWORD=use_a_long_random_password_here
SUPER_ADMIN_NAME=Super Admin
